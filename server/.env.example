# Copy to .env and fill in values. Never commit .env.
PORT=3000

# Atlas: replace <db_password> with your DB user password (URL-encode special chars).
# Optional: use /your-db-name before ? e.g. ...mongodb.net/noor-ai?appName=...
MONGODB_URI=mongodb+srv://USER:<db_password>@cluster0.xxxxx.mongodb.net/?appName=Cluster0&retryWrites=true&w=majority

CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Comma-separated frontend origins (production Vercel URL, etc.)
# CORS_ORIGINS=https://your-frontend.vercel.app
